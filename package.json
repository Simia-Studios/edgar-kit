{
  "name": "edgar-kit",
  "version": "1.2.0",
  "private": false,
  "description": "Type-safe SDK for SEC EDGAR filings, submissions, search, archives, XBRL, financials, and company data.",
  "license": "ISC",
  "files": [
    "dist/**",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && tsdown",
    "build:clean": "tsc --noEmit && tsdown --clean",
    "release": "./publish.sh",
    "format": "oxfmt .",
    "check": "oxfmt --check . && pnpm typecheck && pnpm test && pnpm build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "effect": "3.21.2"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "lefthook": "2.1.6",
    "oxfmt": "0.47.0",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
